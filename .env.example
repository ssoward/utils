SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=your-signing-secret

# Optional: restrict commands to your Slack user ID
# ALLOWED_USER_ID=U0123456789

# Optional: Slack channel for alerts and notifications
# SLACK_CHANNEL_ID=C0123456789

# Hook receiver port (default 3847)
HOOK_PORT=3847

# CLI bridge port (default 3848)
CLI_BRIDGE_PORT=3848

# Scheduler interval in minutes (default 30)
SCHEDULER_INTERVAL_MINUTES=30

# Max messages to keep in the incoming message queue (default 200)
MAX_QUEUE_MESSAGES=200

# Alert thresholds
BATTERY_LOW_THRESHOLD=20
DISK_USAGE_HIGH_THRESHOLD=90
